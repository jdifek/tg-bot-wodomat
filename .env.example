# ============================================================
#  НАСТРОЙКИ БОТА — скопируйте в .env и заполните
# ============================================================

# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=1234567890:AABBCCDDEEFFaabbccddeeff1234567890

# Язык интерфейса бота: ru (русский) или pl (польский)
LOCALE=ru

# API base URL (не менять)
API_BASE_URL=http://api.happy-ti.com:2028

# ---- Настройки мониторинга ----

# Интервал опроса API (секунды, минимум 60 из-за лимитов API)
POLL_INTERVAL_SEC=60

# Интервал отправки алертов в Telegram (секунды)
ALERT_INTERVAL_SEC=300

# Размер батча запросов к API за одну минуту (не более 90!)
BATCH_SIZE=90

# Задержка между запросами внутри батча (мс)
REQUEST_DELAY_MS=350

# ---- Пороги срабатывания ----

# Температура ниже этого значения = алерт (°C)
TEMP_MIN=3

# Температура выше этого значения = алерт (°C)
TEMP_MAX=40

# Аппарат считается оффлайн если нет связи N минут
OFFLINE_MINUTES=15

# Алерт если SIM карта истекает через N дней
SIM_DAYS_WARN=7

# Час отправки ежедневного отчёта о продажах (0-23, серверное время)
DAILY_REPORT_HOUR=8

# ---- Типы устройств для мониторинга (через запятую) ----
# Варианты: shop, shop_liquid, shop_water
DEVICE_TYPES=shop,shop_liquid,shop_water
